# OPENQANT environment configuration
APP_ENV=development
DEFAULT_DATA_SOURCE=Synthetic
TIMEZONE=UTC
LOG_LEVEL=INFO

# AI Agent (optional — rule-based fallback if not set)
OPENAI_API_KEY=

# Strategy defaults (aligned to docs/09_config)
SEASONAL_MOMENTUM_LOOKBACK=20
SEASONAL_MOMENTUM_ENTRY_THRESHOLD=0.02
SEASONAL_MOMENTUM_EXIT_THRESHOLD=-0.01

TREND_BREAKOUT_CHANNEL_WINDOW=30

CRYPTO_MOMENTUM_LOOKBACK=14
CRYPTO_MOMENTUM_ENTRY_THRESHOLD=0.04
CRYPTO_MOMENTUM_EXIT_THRESHOLD=-0.03

SMALL_CAP_REVERSAL_LOOKBACK=10
SMALL_CAP_REVERSAL_ZSCORE_ENTRY=-1.2
SMALL_CAP_REVERSAL_ZSCORE_EXIT=1.0

# Risk defaults
MAX_POSITION_FRACTION=0.10
MAX_DRAWDOWN=0.20

# Backtest defaults
TRANSACTION_COST_BPS=5.0
MIN_CONSENSUS_VOTES=2
